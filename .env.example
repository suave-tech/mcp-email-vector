# Core
NODE_ENV=development
PORT=3000
JWT_SECRET=replace-me

# Token encryption (AES-256 key, 32 bytes base64)
TOKEN_ENCRYPTION_KEY=

# Postgres
DATABASE_URL=postgres://user:pass@localhost:5432/vector_email

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# OpenAI embeddings
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX=email-vectors

# Anthropic (LLM for grounded answers)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google OAuth (Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# Microsoft OAuth (Outlook / Graph)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:3000/api/oauth/microsoft/callback
